{
    "name": "coo1white/cool-tunnel-server-panel",
    "type": "project",
    "description": "Cool Tunnel Server admin panel — Laravel 11 + Filament 3. AGPL-3.0-only; see ../LICENSE. Copyright (C) 2026 coolwhite LLC.",
    "license": "AGPL-3.0-only",
    "require": {
        "php": "^8.2",
        "filament/filament": "^3.2",
        "guzzlehttp/guzzle": "^7.8",
        "laravel/framework": "^11.0",
        "laravel/octane": "^2.17",
        "laravel/tinker": "^2.9",
        "predis/predis": "^2.2",
        "symfony/messenger": "^7.4",
        "symfony/process": "^7.0",
        "symfony/redis-messenger": "^7.4"
    },
    "require-dev": {
        "fakerphp/faker": "^1.23",
        "larastan/larastan": "^3.0",
        "laravel/pint": "^1.13",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.0",
        "phpstan/phpstan": "^2.1",
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        },
        "platform": {
            "ext-redis": "5.3.0"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
