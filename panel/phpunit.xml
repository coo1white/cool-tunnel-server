<?xml version="1.0" encoding="UTF-8"?>
<phpunit xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="vendor/phpunit/phpunit/phpunit.xsd"
         bootstrap="vendor/autoload.php"
         colors="true"
         cacheDirectory=".phpunit.cache"
         executionOrder="random"
         failOnWarning="true"
         failOnRisky="true">

  <!-- Test suites — Feature is HTTP / DB integration, Unit is
       framework-light tests of pure functions / model methods. -->
  <testsuites>
    <testsuite name="Unit">
      <directory>tests/Unit</directory>
    </testsuite>
    <testsuite name="Feature">
      <directory>tests/Feature</directory>
    </testsuite>
  </testsuites>

  <!-- Code-coverage source roots. Filament Resources / Pages live
       under app/Filament; we cover them too even though most logic
       there is config rather than behaviour. -->
  <source>
    <include>
      <directory>app</directory>
    </include>
  </source>

  <!-- Test environment overrides — pinned to deterministic values
       so a developer running `vendor/bin/phpunit` locally gets
       identical behaviour to CI. SQLite in-memory is the canonical
       Laravel-test DB choice: no setup, no isolation between tests
       beyond what RefreshDatabase already gives. -->
  <php>
    <env name="APP_ENV" value="testing"/>
    <!-- A fixed APP_KEY lets cryptographic tests assert against
         deterministic ciphertext when needed. The value here MUST
         differ from any real APP_KEY an operator might use. -->
    <env name="APP_KEY" value="base64:JCsdgKuqbLm9GnIQ6L+8MKf1gfgPYxKCWgVJB8x3qvE="/>
    <env name="APP_MAINTENANCE_DRIVER" value="file"/>
    <env name="BCRYPT_ROUNDS" value="4"/>
    <env name="CACHE_STORE" value="array"/>
    <env name="DB_CONNECTION" value="sqlite"/>
    <env name="DB_DATABASE" value=":memory:"/>
    <env name="LOG_CHANNEL" value="stack"/>
    <env name="MAIL_MAILER" value="array"/>
    <env name="QUEUE_CONNECTION" value="sync"/>
    <env name="SESSION_DRIVER" value="array"/>
    <env name="TELESCOPE_ENABLED" value="false"/>
    <!-- The SubscriptionController v0.0.13 M-panel-2 fix refuses
         to sign with an empty APP_KEY. Tests need a non-empty
         value (already set above) but ALSO need the in-controller
         RateLimiter to use a fast backend — `array` cache above
         provides that. -->
  </php>
</phpunit>
