# Panel-side .env REFERENCE FILE.
#
# DO NOT edit this file. The CANONICAL .env is the repo-root
# `.env` (template at `.env.example` in the repo root). The
# docker-compose `panel` service uses `env_file: - .env`
# pointing at the REPO-ROOT .env, NOT this file. Setting values
# here has NO EFFECT — they're shadowed by the env_file
# injection at container start.
#
# This file exists only as a quick reference for what Laravel-
# side keys the panel container ultimately reads.
#
# Post-v0.0.33 SNI router architecture: the panel sits at
# `https://${PANEL_DOMAIN}/admin`, NOT `https://${DOMAIN}/admin`.
# Legacy installs with the apex variant are auto-migrated by
# scripts/update.sh on next `make update` (the v0.0.54
# `${DOMAIN} → ${PANEL_DOMAIN}` backfill).

APP_NAME="Cool Tunnel Server"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://panel.example.com/admin
APP_TIMEZONE=UTC

LOG_CHANNEL=stderr
LOG_LEVEL=info

DB_CONNECTION=mysql
DB_HOST=db
DB_PORT=3306
DB_DATABASE=cooltunnel
DB_USERNAME=cooltunnel
DB_PASSWORD=

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

CACHE_STORE=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120

# Where the Rust core lives + where it reads its inputs from.
CT_CORE_BIN=/usr/local/bin/ct-server-core
CADDYFILE_TEMPLATE=/srv/caddy/Caddyfile.tpl
CADDYFILE_PATH=/etc/caddy/Caddyfile
CADDY_ADMIN_SOCKET=/run/caddy/admin.sock
CT_MANIFESTS_DIR=/srv/manifests
