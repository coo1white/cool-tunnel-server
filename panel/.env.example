# Panel-side .env. The compose file copies this from the repo root
# .env, so you usually don't edit this file directly — just edit the
# repo-root one.

APP_NAME="Cool Tunnel Server"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://example.com/admin
APP_TIMEZONE=UTC

LOG_CHANNEL=stderr
LOG_LEVEL=info

DB_CONNECTION=mysql
DB_HOST=db
DB_PORT=3306
DB_DATABASE=cooltunnel
DB_USERNAME=cooltunnel
DB_PASSWORD=

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

CACHE_STORE=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120

# Where the Rust core lives + where it reads its inputs from.
CT_CORE_BIN=/usr/local/bin/ct-server-core
CADDYFILE_TEMPLATE=/srv/caddy/Caddyfile.tpl
CADDYFILE_PATH=/etc/caddy/Caddyfile
CADDY_ADMIN_SOCKET=/run/caddy/admin.sock
CT_MANIFESTS_DIR=/srv/manifests
