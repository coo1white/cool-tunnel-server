#!/usr/bin/env bash
# SPDX-License-Identifier: AGPL-3.0-only
# ct — top-level operator dispatcher (brew-style).
#
# A single short command for every workflow a noob operator needs:
#
#   ct install      first-time bootstrap on a fresh VPS
#   ct doctor       read-only health dashboard
#   ct update       pull latest, load release images, hot-swap
#   ct status       one-shot "what's running"
#   ct logs         tail every container's logs
#   ct backup       snapshot db + .env + caddy data
#   ct restore      recover from a backup tarball
#   ct render <t>   re-render Caddyfile or singbox config from the DB
#   ct help [topic] plain-English topic docs (no args = list topics)
#   ct version      print the deployed release tag + git sha
#   ct --help       this message
#
# All commands wrap the underlying scripts/*.sh — there is no
# behaviour difference from `make <target>`. The point of `ct` is
# muscle-memory parity with brew / git / docker so a new operator
# can guess the command instead of reading the Makefile.
#
# Why a separate dispatcher (vs just symlinks to each script):
#   - One discoverable surface: `ct --help` lists everything.
#   - Subcommand routing lets us add new top-level UX later
#     without changing each script's invocation.
#   - Keeps `make <target>` working for CI / muscle memory from
#     v0.1.1-era operators; the two are interchangeable.
#
# Install hint (optional — `ct` works fine as `./ct` from the repo):
#   sudo ln -sf "$(pwd)/ct" /usr/local/bin/ct

set -uo pipefail

# Resolve to the directory containing this script so `ct` works
# regardless of $PWD when invoked via PATH symlink.
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cd "$SCRIPT_DIR" || exit 1

# ---------- Help -------------------------------------------------

show_help() {
    cat <<'EOF'
ct — Cool Tunnel Server operator CLI

USAGE
  ct <command> [args...]

EVERYDAY COMMANDS
  install        first-time bootstrap on a fresh VPS (~5-10 min)
  reinstall      rerun install safely; asks before any data wipe
  doctor         read-only health dashboard (PASS / WARN / FAIL)
  update         pull the latest release, load release images, hot-swap
  status         one-shot "what's running" check
  logs           tail every container's logs

DEEPER COMMANDS
  backup         snapshot db + .env + caddy data into backups/
  restore <f>    recover from a backup tarball
  render <tgt>   re-render generated config (targets: caddyfile, singbox)
  auto-update    unattended release-pulling agent (default OFF)
                   `ct auto-update enable`   add daily cron entry
                   `ct auto-update disable`  remove the cron entry
                   `ct auto-update now`      run once interactively
                   `ct auto-update status`   show on/off state

DISCOVERY
  help [topic]   plain-English explanation of a topic; no args -> list
  version        print release tag + git sha
  --help, -h     this message

GETTING UNSTUCK
  If anything looks wrong, start with:
      ct doctor
  It prints PASS / WARN / FAIL rows with remediation hints and the
  service-specific log commands to run next.

EOF
}

# ---------- Version ----------------------------------------------

show_version() {
    # Prefer panel's config.php (single source of truth across the
    # PHP / Rust / manifest cluster); fall back to git describe so
    # a bare clone without panel build still produces something.
    local v
    if v=$(grep -E "^\s*'version'\s*=>" panel/config/cool-tunnel.php 2>/dev/null \
            | head -1 | sed -E "s/.*'([0-9.]+)'.*/\1/"); then
        :
    else
        v=$(git describe --tags --always --dirty 2>/dev/null || echo "unknown")
    fi
    local sha
    sha=$(git rev-parse --short HEAD 2>/dev/null || echo "no-git")
    printf 'ct (cool-tunnel-server) v%s  (git %s)\n' "$v" "$sha"
}

# ---------- Dispatch ---------------------------------------------

# ---------- auto-update subcommand cluster -----------------------
#
# `ct auto-update` orchestrates the unattended-release-pulling
# agent. Default-OFF (we never auto-upgrade a deployment unless the
# operator opts in). `enable` drops a /etc/cron.daily symlink that
# runs scripts/auto_update.sh --quiet once a day.

CRON_SYMLINK=/etc/cron.daily/ct-auto-update

auto_update_subcommand() {
    local sub="${1:-status}"
    case "$sub" in
        now|run|"")
            shift || true
            dispatch_via_operator auto-update "" "$@"
            ;;
        enable)
            if [[ -L "$CRON_SYMLINK" || -e "$CRON_SYMLINK" ]]; then
                printf 'ct auto-update: already enabled (%s exists)\n' "$CRON_SYMLINK"
                ls -la "$CRON_SYMLINK"
                return 0
            fi
            printf 'ct auto-update: installing %s -> %s/scripts/auto_update.sh\n' \
                "$CRON_SYMLINK" "$SCRIPT_DIR"
            if [[ $EUID -ne 0 ]]; then
                printf '  ! needs root to write /etc/cron.daily; re-run with sudo\n' >&2
                return 1
            fi
            ln -sf "$SCRIPT_DIR/scripts/auto_update.sh" "$CRON_SYMLINK"
            # cron.daily entries must be executable + name-restricted
            # (anacron skips files containing '.', a '_', etc. -- our
            # symlink uses a safe basename, so we're fine).
            chmod +x "$CRON_SYMLINK"
            printf '  ✓ enabled. Next run: tomorrow ~06:25 UTC (anacron-window).\n'
            printf '  Tail the log:  journalctl -t cron --since today\n'
            printf '  Disable:       ct auto-update disable\n'
            ;;
        disable)
            if [[ ! -L "$CRON_SYMLINK" && ! -e "$CRON_SYMLINK" ]]; then
                printf 'ct auto-update: already disabled (no %s)\n' "$CRON_SYMLINK"
                return 0
            fi
            if [[ $EUID -ne 0 ]]; then
                printf 'ct auto-update: needs root to remove %s; re-run with sudo\n' \
                    "$CRON_SYMLINK" >&2
                return 1
            fi
            rm -f "$CRON_SYMLINK"
            printf '  ✓ disabled. Manual `ct update` is unaffected.\n'
            ;;
        status)
            printf 'ct auto-update status\n'
            if [[ -L "$CRON_SYMLINK" || -e "$CRON_SYMLINK" ]]; then
                printf '  state:   %sENABLED%s\n' '' ''
                printf '  symlink: '
                ls -la "$CRON_SYMLINK"
            else
                printf '  state:   DISABLED (no %s)\n' "$CRON_SYMLINK"
                printf '  enable:  sudo ct auto-update enable\n'
            fi
            printf '  manual run (interactive, no schedule needed):\n'
            printf '    ct auto-update now\n'
            ;;
        --help|-h|help)
            cat <<'EOF'
ct auto-update — unattended release-pulling agent

SUBCOMMANDS
  now        Run the agent right now (interactive, verbose).
             Pulls origin, compares with deployed version, runs
             `ct update` if a new release exists.
  enable     Install /etc/cron.daily/ct-auto-update symlink (needs
             sudo). Runs the agent in --quiet mode once a day.
  disable    Remove the cron.daily symlink (needs sudo).
  status     Show whether the cron entry is installed.

DEFAULT (no subcommand)
  Same as `ct auto-update now`.

SAFETY
  - Default-OFF: a fresh install does NOT auto-upgrade.
  - Aborts if the running stack is unhealthy (you don't want an
    unattended agent layering a release on top of an incident).
  - Idempotent: re-running mid-upgrade picks up where it left off.
  - flock'd: two concurrent runs can't race.
EOF
            ;;
        *)
            printf 'ct auto-update: unknown subcommand: %s\n' "$sub" >&2
            printf 'try: ct auto-update --help\n' >&2
            return 1
            ;;
    esac
}

# ---------- ct-operator binary self-bootstrap --------------------
#
# Compare the binary on disk against panel/config/cool-tunnel.php
# (the panel-deployed version, our canonical source of truth). If
# the binary is missing or stale, fetch the matching binary from the
# GitHub Release before dispatching. Closes both deploy-skew holes:
#   - stale binary after a version bump
#   - no binary after `git pull` moves a VPS onto a binary-only verb
# Skip via CT_SKIP_OPERATOR_BOOTSTRAP=1.
operator_bootstrap_if_skewed() {
    local op_bin="$1"
    [[ "${CT_SKIP_OPERATOR_BOOTSTRAP:-}" == "1" ]] && return 0

    local deployed
    deployed=$(grep -E "^\s*'version'\s*=>" "$SCRIPT_DIR/panel/config/cool-tunnel.php" 2>/dev/null \
        | head -1 | sed -E "s/.*'([0-9.]+)'.*/\1/" || true)
    [[ -z "$deployed" ]] && return 0   # Can't read panel config → skip.

    local installed=""
    if [[ -x "$op_bin" ]]; then
        installed=$("$op_bin" version 2>/dev/null | head -1 | tr -d '[:space:]' || true)
        [[ "$installed" == "$deployed" ]] && return 0   # Already in sync.
    fi

    if [[ -z "$installed" ]]; then
        printf 'ct: operator binary missing; fetching v%s…\n' "$deployed" >&2
    else
        printf 'ct: operator binary v%s ≠ deployed v%s; fetching matching binary…\n' \
            "$installed" "$deployed" >&2
    fi

    local arch="$2" os="$3"
    local url="https://github.com/coo1white/cool-tunnel-server/releases/download/v${deployed}/ct-operator-${os}-${arch}"
    local sums="https://github.com/coo1white/cool-tunnel-server/releases/download/v${deployed}/SHA256SUMS"
    local target="ct-operator-${os}-${arch}"
    local tmp; tmp=$(mktemp "${TMPDIR:-/tmp}/ct-operator.XXXXXX") || return 1
    local curl_common=(
        -fsSL
        --connect-timeout "${CT_FETCH_CONNECT_TIMEOUT:-10}"
        --max-time "${CT_FETCH_MAX_TIME:-300}"
        --retry "${CT_FETCH_RETRIES:-2}"
        --retry-delay 2
    )

    if ! curl "${curl_common[@]}" "$url" -o "$tmp"; then
        printf 'ct: download failed (%s); continuing with stale binary\n' "$url" >&2
        rm -f "$tmp"
        return 0
    fi
    # SHA-256 verify against the release's manifest.
    if command -v sha256sum >/dev/null 2>&1; then
        local sums_body expected actual
        sums_body=$(curl "${curl_common[@]}" "$sums" 2>/dev/null || true)
        if [[ -n "$sums_body" ]]; then
            expected=$(printf '%s' "$sums_body" | awk -v t="$target" '$2==t || $2=="*"t {print $1; exit}')
            actual=$(sha256sum "$tmp" | awk '{print $1}')
            if [[ -n "$expected" && "$expected" != "$actual" ]]; then
                printf 'ct: sha256 mismatch (expected %s, got %s); refusing\n' \
                    "$expected" "$actual" >&2
                rm -f "$tmp"
                return 1
            fi
        fi
    fi
    chmod +x "$tmp"
    mkdir -p "$(dirname "$op_bin")"
    mv "$tmp" "$op_bin"
    printf 'ct: bootstrapped operator binary to v%s\n' "$deployed" >&2
}

# ---------- ct-operator binary preference ------------------------
#
# For operator-owned subcommands, prefer the compiled ct-operator binary
# in operator/bin/. Only a few old commands still have explicit shell
# fallbacks; install/update/doctor/backup/restore are binary-first
# production paths.
dispatch_via_operator() {
    local subcmd="$1"; shift
    local fallback="$1"; shift
    local arch=""
    case "$(uname -m)" in
        x86_64)        arch=x64 ;;
        aarch64|arm64) arch=arm64 ;;
    esac
    if [[ -n "$arch" ]]; then
        local os
        os=$(uname -s | tr '[:upper:]' '[:lower:]')
        local op_bin="$SCRIPT_DIR/operator/bin/ct-operator-${os}-${arch}"
        operator_bootstrap_if_skewed "$op_bin" "$arch" "$os"
        if [[ -x "$op_bin" ]]; then
            exec "$op_bin" "$subcmd" "$@"
        fi
    fi
    # Empty fallback => binary-only subcommand. Error
    # rather than silently doing nothing.
    if [[ -z "$fallback" ]]; then
        printf 'ct %s: requires the ct-operator binary (operator/bin/ct-operator-<os>-<arch>); no shell fallback exists for this subcommand.\n' "$subcmd" >&2
        printf '  build it locally:        make operator-build\n' >&2
        printf '  or install from release: see docs/operator.md\n' >&2
        exit 2
    fi
    exec "$fallback" "$@"
}

# ---------- render subcommand ------------------------------------
#
# `ct render <target> [args]` triggers config re-rendering in the
# panel container. v0.4.x has two live targets: caddyfile and singbox.
# `haproxy` stays retired and gets a friendly hint for old runbooks.
#
# Prefer the compiled ct-operator binary when present; the binary
# carries the target-specific logic. Fall back to
# `scripts/render-caddyfile.sh` for caddyfile otherwise.
render_subcommand() {
    local target="${1:-}"
    [[ -n "$target" ]] && shift
    case "$target" in
        caddyfile|singbox) ;;
        haproxy)
            printf 'ct render: target "%s" was retired in v0.2.0\n' "$target" >&2
            printf '  use:  ct render caddyfile   or   ct render singbox\n' >&2
            exit 2
            ;;
        ""|-h|--help)
            printf 'ct render — re-render generated config from the DB\n\n' >&2
            printf 'usage: ct render <caddyfile|singbox> [--if-changed]\n' >&2
            [[ -z "$target" ]] && exit 2 || exit 0
            ;;
        *)
            printf 'ct render: unknown target: %s\n' "$target" >&2
            printf 'usage: ct render <caddyfile|singbox>\n' >&2
            exit 2
            ;;
    esac
    local arch=""
    case "$(uname -m)" in
        x86_64)        arch=x64 ;;
        aarch64|arm64) arch=arm64 ;;
    esac
    if [[ -n "$arch" ]]; then
        local os
        os=$(uname -s | tr '[:upper:]' '[:lower:]')
        local op_bin="$SCRIPT_DIR/operator/bin/ct-operator-${os}-${arch}"
        if [[ -x "$op_bin" ]]; then
            exec "$op_bin" render "$target" "$@"
        fi
    fi
    if [[ "$target" == "caddyfile" ]]; then
        exec "./scripts/render-${target}.sh" "$@"
    fi
    if command -v bun >/dev/null 2>&1; then
        exec bun run "$SCRIPT_DIR/operator/src/index.ts" render "$target" "$@"
    fi
    printf 'ct render %s: requires bun or the ct-operator binary; no shell fallback exists for this target.\n' "$target" >&2
    printf '  run from source:         install bun\n' >&2
    printf '  build it locally:        make operator-build\n' >&2
    printf '  or install from release: see docs/operator.md\n' >&2
    exit 2
}

# ---------- Dispatch ---------------------------------------------

cmd="${1:-help}"
[[ $# -gt 0 ]] && shift

case "$cmd" in
    install)      exec ./scripts/install.sh             "$@" ;;
    reinstall)    exec ./scripts/install.sh             "$@" ;;
    doctor)       dispatch_via_operator doctor    "" "$@" ;;
    update)       dispatch_via_operator update    "" "$@" ;;
    backup)       dispatch_via_operator backup    "" "$@" ;;
    restore)      dispatch_via_operator restore   "" "$@" ;;
    render)       render_subcommand "$@" ;;
    auto-update)  auto_update_subcommand "$@" ;;
    status)       exec make status ;;
    logs)         exec make logs ;;
    help)         dispatch_via_operator help      "" "$@" ;;
    version|--version|-V) show_version ;;
    -h|--help|"")
        show_help
        ;;
    *)
        printf '%s: unknown command: %s\n\n' "$0" "$cmd" >&2
        show_help >&2
        exit 1
        ;;
esac
