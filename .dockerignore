# What NOT to ship into Docker build contexts. Keeps the contexts
# small and stops local secrets from accidentally landing in an
# image layer.

# Local secrets — must never be in any image.
.env
.env.*.local
.env.local
operator/signing.key
backups/

# VCS + IDE noise.
.git/
.gitignore
.github/
.vscode/
.idea/
*.swp
.DS_Store

# Rust build artefacts.
core/target/
core/bin/
**/target/
core/Cargo.lock        # we want it in the image actually — see negation below

# Bun local state.
operator/node_modules/
singbox-core/node_modules/
singbox-core/bin/
operator/bin/

# Generated / one-off documentation outputs.
*.tar.gz
*.tar
*.tar.bz2
*.tgz
.runtime/
release-assets/

# Re-allow files that were excluded by patterns above but we
# definitely want in the build context.
!core/Cargo.lock
