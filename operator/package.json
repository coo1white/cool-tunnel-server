{
  "name": "ct-operator",
  "version": "0.1.10",
  "description": "Cool Tunnel Server operator CLI — doctor/fix/readiness/self-update, compiled to a single Bun binary.",
  "license": "AGPL-3.0-only",
  "type": "module",
  "private": true,
  "engines": {
    "bun": ">=1.1.0"
  },
  "scripts": {
    "build": "bun run build.ts",
    "build:linux-x64": "bun run build.ts linux-x64",
    "build:linux-arm64": "bun run build.ts linux-arm64",
    "build:darwin-arm64": "bun run build.ts darwin-arm64",
    "test": "bun test",
    "typecheck": "bunx tsc --noEmit",
    "start": "bun run src/index.ts"
  },
  "devDependencies": {
    "@types/bun": "^1.1.0",
    "typescript": "^5.4.0"
  }
}
