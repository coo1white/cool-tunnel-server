# Top-level .editorconfig. Source of truth for whitespace and line
# endings across every language. CI does not enforce these — it
# delegates to language-specific tools (rustfmt, php-cs-fixer if you
# add it later, shellcheck) — but having them here makes editor
# defaults consistent across contributors.
#
# Reference: https://editorconfig.org/

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.{md,markdown}]
# Markdown trailing-whitespace can be meaningful (forced linebreak),
# so don't auto-trim there.
trim_trailing_whitespace = false

[*.{yml,yaml,json,toml}]
indent_size = 2

[Makefile]
# Make requires real tabs.
indent_style = tab

[*.{rs,php}]
indent_size = 4

[*.{sh,bash}]
indent_size = 4
