# Caddyfile for FrankenPHP — the panel's web tier (post-runtime-
# swap). Replaces docker/panel/nginx.conf.
#
# This Caddy instance lives INSIDE the panel container, alongside
# the PHP runtime. It is NOT the same as the apex-domain Caddy
# container (which handles ACME for the public TLS cert); the two
# are independent and can't conflict — different containers, no
# port overlap (panel listens on container :9000 → loopback host
# :9000; apex Caddy listens on :443).
#
# What this config preserves from the nginx era:
#   - Loopback bind on :9000 (admin reaches via SSH-local-forward).
#   - Document root at /var/www/html/public.
#   - Hidden files and `vendor`/`storage`/`tests` paths denied.
#   - Subscription-token access-log masking (the v0.0.14 anti-
#     censorship invariant — token must NEVER hit a log file).
#   - `Server` header stripped (no `Server: Caddy` fingerprint).
#
# What this config adds:
#   - HTTP/2 native (auto on Caddy h1->h2 negotiation, no FPM
#     equivalent existed).
#   - HTTP/3 listener — zero-config in Caddy, cosmetic on this
#     SSH-tunnel-bound deploy (UDP doesn't traverse SSH's TCP
#     forwarder), but enabled so a future public-fronted panel
#     deployment picks it up automatically.
#   - Worker mode binding via the `worker` directive — Octane
#     supervises the worker process count via `octane:start`, but
#     the FrankenPHP global config below scopes the worker entry
#     point so `frankenphp_handle_request()` knows what file to
#     evaluate.

{
    # Enable HTTP/2 + HTTP/3 (HTTP/3's reach is cosmetic on this
    # loopback-bound listener — UDP/QUIC doesn't traverse SSH's
    # TCP forwarder — but it pays off automatically when the panel
    # is fronted by a public TLS terminator in v0.1).
    servers {
        protocols h1 h2 h3
    }

    # FrankenPHP global block. The worker directive declares the
    # PHP file FrankenPHP loads ONCE per worker; subsequent
    # requests reuse that boot. Octane scaffolds
    # public/frankenphp-worker.php on `octane:install`.
    frankenphp {
        # Number of long-lived workers. Each holds the full Laravel
        # boot in memory (~30-50 MiB after Filament loads). At 4
        # workers the steady-state ~200 MiB sits within the panel
        # container's 320 MiB mem_limit alongside the queue worker,
        # scheduler, and ct-server-core daemon.
        #
        # Operators on bigger boxes who want more workers edit
        # `num` below and rebuild the panel image. Env-driven
        # tuning was dropped in PR #10 along with the
        # `octane:start` CLI wrapper — the OCTANE_WORKERS env
        # was an octane:start option, not a FrankenPHP-direct
        # one. Templating this Caddyfile to read an env var is a
        # ~10-line follow-up if the operator-facing surface
        # justifies it.
        #
        # `num_threads` MUST be strictly greater than `worker
        # num`. FrankenPHP exits at boot with `num_threads (N)
        # must be greater than the number of worker threads (N)`
        # if equal — the worker pool consumes N threads and the
        # in-process Caddy needs at least one spare to handle
        # incoming requests / ACME maintenance / admin endpoint
        # traffic. Pre-v0.0.60 this said `num_threads 4` matching
        # `worker num 4`, which FrankenPHP rejected; the v0.0.59
        # Caddyfile-shadow bug was masking it (the Caddyfile
        # FrankenPHP actually loaded had no frankenphp block at
        # all, so the validation never ran). 8 = 4 worker threads
        # + 4 headroom; bumps to 12-16 are sensible on bigger
        # boxes alongside `worker num` increases. (post-v0.0.59
        # hotfix.)
        num_threads 8
        worker {
            file /var/www/html/public/frankenphp-worker.php
            num 4
        }
    }
}

# Listen on plain HTTP on container port 9000, all interfaces.
# Host-side loopback gating is enforced by docker-compose's
# `127.0.0.1:9000:9000` port mapping — packets from outside the
# host can't reach the container at all. SSH-tunnel users hit
# the host's loopback via `ssh -L 9000:127.0.0.1:9000 <host>`.
#
# IMPORTANT: do NOT change this back to `http://127.0.0.1:9000`
# — that binds the listener to the container's OWN loopback
# only. Docker's iptables DNAT routes mapped traffic to the
# container's bridge interface (eth0), not its loopback, so a
# loopback-bound listener accepts the docker-internal
# healthcheck call (which runs inside the container, against
# the same loopback) but silently fails every SSH-tunnel
# request from the operator's laptop. Caught in the v0.0.58
# round-5 audit.
#
# Once the v0.1 public-fronted panel architecture lands (R1-3
# in the SNI-router design), this listener moves to the
# operator-managed apex domain with TLS at the SNI router.
http://:9000 {
    root * /var/www/html/public

    # Strip `Server` header on every response (defence in depth —
    # also covered by the global `servers` block above; this is the
    # per-site override in case the global is overridden later).
    header -Server

    # Hardened path denials — match the pre-swap nginx behaviour.
    @hidden {
        path /.*
    }
    respond @hidden 404

    @sensitive {
        path /vendor/* /storage/* /tests/*
    }
    respond @sensitive 404

    # Subscription endpoint — skip access logging entirely. The
    # full URL contains the HMAC-bound token; persisting it in
    # plaintext on local disk extends the credential's lifetime
    # far past per-request scope (rotating ops staff, log
    # shipping pipelines, forgotten log archives are real
    # leakage paths). Pre-swap nginx used a `map` block to
    # rewrite the request line; under Caddy `log_skip` drops the
    # whole entry. Operator loses request-count visibility on
    # this endpoint — counts are still available via the panel's
    # own DB metrics. (v0.0.14 anti-censorship invariant.)
    @subscription {
        path /api/v1/subscription/*
    }
    log_skip @subscription

    # Standard Caddy access log to stdout for operator
    # `docker compose logs panel` visibility.
    log {
        output stdout
        format console
    }

    # Hand every other request to the FrankenPHP worker pool.
    # `php_server` is FrankenPHP's combined "static-files-then-
    # PHP-fallback" handler; equivalent to the nginx
    # `try_files $uri $uri/ /index.php?$query_string` + `location
    # ~ \.php$ { fastcgi_pass ... }` pair, but in-process.
    php_server
}
