# Cool Tunnel Server — environment template.
#
# Copy to .env and edit before running install.sh:
#     cp .env.example .env && $EDITOR .env
#
# Generate strong random values for every *_PASSWORD line. A quick way:
#     openssl rand -base64 32
#

# --- Public-facing identity ----------------------------------------
# Domain that resolves to this host. sing-box uses it as the SNI/Host
# the proxy clients connect to (VLESS+Reality traffic). Caddy uses it
# for ACME — the cert lands in caddy_data and sing-box reads it from
# there. Caddy's layer-4 SNI splitter demuxes :443 into panel traffic
# (PANEL_DOMAIN → inner :8443) vs. proxy traffic (everything else →
# tcp/ct-singbox:443).
DOMAIN=proxy.example.com

# Subdomain that resolves to the SAME host and serves the Filament
# admin panel (https://${PANEL_DOMAIN}/admin) plus subscription URLs
# (https://${PANEL_DOMAIN}/api/v1/subscription/<token>). Add a second
# DNS A record for this name pointing at the same VPS IP — install.sh
# step 3 will sanity-check both.
#
# Why a separate subdomain (not /admin on the proxy domain): :443 is
# owned by Caddy's layer-4 splitter (mholt/caddy-l4), which routes by
# TLS SNI without decrypting — there is no path-based routing
# available at that layer. Each backend (sing-box, panel-inner Caddy)
# sees its own SNI and terminates its own TLS. Splitting by subdomain
# is the cleanest SNI-router-compatible design. Anti-tracking aside:
# a probe finding the proxy domain does not lead them to the admin
# panel — the two are demuxed by SNI and the panel hostname is
# independently enumerable. Set this to a name
# that doesn't pattern-match the proxy domain if you want defence in
# depth (e.g. dashboard.example.com instead of panel.proxy.example.com).
# (R1-1 / R1-2 in 2026-05-04 audit; landed in v0.0.33.)
PANEL_DOMAIN=panel.proxy.example.com

# Email passed to the ACME directory for certificate registration.
# Used for both DOMAIN and PANEL_DOMAIN certs — Let's Encrypt
# associates renewal notifications with this one address.
ACME_EMAIL=admin@example.com

# ACME directory. Default is Let's Encrypt production. Switch to
# https://acme-staging-v02.api.letsencrypt.org/directory while testing
# so you don't burn through the LE rate-limit budget.
ACME_DIRECTORY=https://acme-v02.api.letsencrypt.org/directory


# --- Panel (Laravel) ----------------------------------------------
APP_NAME="Cool Tunnel Server"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://${PANEL_DOMAIN}/admin
APP_TIMEZONE=UTC
LOG_CHANNEL=stderr
LOG_LEVEL=info


# --- Database -----------------------------------------------------
DB_CONNECTION=mysql
DB_DATABASE=cooltunnel
DB_USERNAME=cooltunnel
DB_PASSWORD=change-me-please
DB_ROOT_PASSWORD=change-me-too


# --- Redis --------------------------------------------------------
REDIS_PASSWORD=change-me-also
REDIS_TIMEOUT=1.0
REDIS_READ_TIMEOUT=1.0
REDIS_READ_WRITE_TIMEOUT=1.0
REDIS_RETRY_INTERVAL_MS=100
CACHE_STORE=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis

# Admin-panel session lifetime, in minutes. Defaults to 120 (2h).
# Tradeoff: shorter = re-login friction for the operator;
# longer = bigger window where a stolen session cookie remains
# usable. Filament's login throttle (5 attempts / minute / IP+
# email, 20 / minute / IP, 20 / minute / email — see
# AppServiceProvider's RateLimiter::for('login')) caps brute-
# force regardless of this value. Round-29 surfaced this as an
# under-documented operator knob.
SESSION_LIFETIME=120

# Session cookies. v0.0.33 landed the SNI router (R1-1 / R1-2), so
# the panel is now reachable at https://${PANEL_DOMAIN}/admin over
# real TLS terminated at the inner panel Caddy listener (the layer-4
# SNI splitter routes PANEL_DOMAIN traffic to it). Default is `true`
# so the cookie carries the `Secure` flag and the browser refuses to
# send it back over plain HTTP — defence against an operator who
# accidentally proxies the panel through `http://`.
#
# The legacy SSH-tunnel access path (`ssh -L 9000:127.0.0.1:9000 host`
# + `http://127.0.0.1:9000/admin`) still works because the panel
# container also binds 127.0.0.1:9000 on the host. If you rely on
# that path AND set SESSION_SECURE_COOKIE=true, login through the
# tunnel will appear to succeed but the next request will land
# logged-out (browser refused to send the cookie over plain HTTP).
# Flip this to `false` if SSH-tunnel access is your primary path.
SESSION_SECURE_COOKIE=true


# --- Octane runtime ----------------------------------------------
# v0.0.58 swapped the panel runtime from PHP-FPM to FrankenPHP +
# Laravel Octane (worker mode). The Octane CLI (`php artisan
# octane:start`) defaults to `roadrunner` if OCTANE_SERVER isn't
# set, which is wrong for this project. Production doesn't go
# through octane:start (supervisord runs `frankenphp run --config
# /etc/caddy/Caddyfile` directly with the project's Caddyfile;
# the worker block loads vendor/laravel/octane/bin/frankenphp-
# worker.php). But a developer running `octane:start` locally
# would get the wrong server without this. Round-29 env-contract
# audit.
OCTANE_SERVER=frankenphp


# --- Filament panel auth -----------------------------------------
# Filament uses Laravel's auth scaffolding. The first admin is created
# during `install.sh` via `php artisan make:filament-user`.

# --- Anti-tracking defaults --------------------------------------
ANTI_TRACKING_HIDE_IP=true
ANTI_TRACKING_HIDE_VIA=true
ANTI_TRACKING_PROBE_RESISTANCE=true
ANTI_TRACKING_DOH_RESOLVER=https://1.1.1.1/dns-query

# --- sing-box outbound dial policy --------------------------------
# Server-side direct outbound address-family strategy. cool-tunnel-server
# is IPv4-only by default for reproducible Docker/Rust builds and stable
# VPS egress.
SINGBOX_DIRECT_DOMAIN_STRATEGY=ipv4_only
SINGBOX_DIRECT_CONNECT_TIMEOUT=2s
SINGBOX_DIRECT_FALLBACK_DELAY=100ms

# --- Resource tuning (low-mem VPS) -------------------------------
# Defaults below are sized for a 1 vCPU / 1 GB VPS. Raise on bigger
# boxes; lower if you have an even tighter budget.
#
# FrankenPHP worker pool. Replaces the pre-FrankenPHP PHP_FPM_*
# variables. Each worker holds a long-lived Laravel boot in memory
# (~30-50 MiB after Filament loads) and serves many requests
# without repaying boot cost — that's the ~3-5x latency improvement
# on the panel "Save → reload" cycle the runtime swap was motivated
# by.
#
# Worker count is configured in `docker/panel/Caddyfile` (the
# `worker { file ... num <N> }` block), NOT via env. Default is
# 4 — comfortable on a 1 vCPU / 1 GB VPS alongside the queue
# worker, scheduler, and ct-server-core daemon. To change for a
# bigger box: edit the Caddyfile's `num` value and rebuild the
# panel image. (Operator follow-up for env-driven tuning is a
# small Caddyfile templating change in v0.0.58 if needed.)

# Build-only switch — read by `docker compose build core-builder`,
# not by any running container. Set to `release-small` for the
# low-mem-VPS install path; cuts peak compile-time RAM from ~1.5-2 GB
# to ~0.6-0.9 GB AND roughly halves cargo build time (release-small
# disables fat LTO and unlocks codegen-units = 16 parallelism), at
# the cost of ~5-15 % runtime speed. The default `release` profile
# in core/Cargo.toml stays the production target for boxes that
# can spare the build RAM and don't mind the longer rebuild.
#
# Wired through docker-compose.yml's core-builder build.args block
# (v0.0.38). Set this value, then run `make update` — no manual
# --build-arg needed. To verify what BuildKit will use:
#   docker compose --profile build-only config core-builder \
#     | grep -A2 args:
CT_CORE_BUILD_PROFILE=release
