# Cool Tunnel Server — environment template.
#
# Copy to .env and edit before running install.sh:
#     cp .env.example .env && $EDITOR .env
#
# Generate strong random values for every *_PASSWORD line. A quick way:
#     openssl rand -base64 32
#

# --- Public-facing identity ----------------------------------------
# Domain that resolves to this host. Caddy uses it for ACME and as the
# SNI/Host the proxy clients connect to.
DOMAIN=proxy.example.com

# Email passed to the ACME directory for certificate registration.
ACME_EMAIL=admin@example.com

# ACME directory. Default is Let's Encrypt production. Switch to
# https://acme-staging-v02.api.letsencrypt.org/directory while testing
# so you don't burn through the LE rate-limit budget.
ACME_DIRECTORY=https://acme-v02.api.letsencrypt.org/directory


# --- Panel (Laravel) ----------------------------------------------
APP_NAME="Cool Tunnel Server"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://${DOMAIN}/admin
APP_TIMEZONE=UTC
LOG_CHANNEL=stderr
LOG_LEVEL=info


# --- Database -----------------------------------------------------
DB_CONNECTION=mysql
DB_DATABASE=cooltunnel
DB_USERNAME=cooltunnel
DB_PASSWORD=change-me-please
DB_ROOT_PASSWORD=change-me-too


# --- Redis --------------------------------------------------------
REDIS_PASSWORD=change-me-also
CACHE_STORE=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis


# --- Clash API bearer seed ---------------------------------------
# Per-install random seed. ct-server-core derives the clash-API
# bearer token as sha256("ct-clash-secret-v1:" + seed); sing-box's
# clash listener validates the same hash. install.sh generates a
# fresh value here from /dev/urandom on first boot if this is empty.
# Rotate with: sed -i "s|^CT_CLASH_SECRET_SEED=.*|CT_CLASH_SECRET_SEED=$(openssl rand -hex 32)|" .env
# then `docker compose restart panel sing-box`.
CT_CLASH_SECRET_SEED=


# --- Filament panel auth -----------------------------------------
# Filament uses Laravel's auth scaffolding. The first admin is created
# during `install.sh` via `php artisan make:filament-user`.

# --- Anti-tracking defaults --------------------------------------
ANTI_TRACKING_HIDE_IP=true
ANTI_TRACKING_HIDE_VIA=true
ANTI_TRACKING_PROBE_RESISTANCE=true
ANTI_TRACKING_DOH_RESOLVER=https://1.1.1.1/dns-query


# --- Network — clash management plane ----------------------------
# `ct-clash` is the internal-only docker network carrying clash-API
# HTTP between panel and sing-box (H3 in 2026-05-05 audit). The
# defaults below work on most fresh VPS hosts. Override BOTH
# together if your docker daemon already has another network in
# 172.30.0.0/24 — collisions show up as
#     "Pool overlaps with other one on this address space"
# during `docker compose up`. Common conflicts: corporate VPN
# bridges, Tailscale subnet routes, k8s flannel, another compose
# stack. Pick a free /24 inside docker's default-address-pool
# (172.16/12 unless tuned in /etc/docker/daemon.json) and update
# both lines plus CT_CLASH_LISTEN — they all reference the same
# IP. (v0.0.14 anti-collision hardening.)
CT_CLASH_SUBNET=172.30.0.0/24
CT_CLASH_SINGBOX_IP=172.30.0.10


# --- Resource tuning (low-mem VPS) -------------------------------
# Defaults below are sized for a 1 vCPU / 1 GB VPS. Raise on bigger
# boxes; lower if you have an even tighter budget.
#
# PHP-FPM pool. `ondemand` only spawns workers on incoming request,
# so an idle panel costs ~0 worker slots. Switch to `dynamic` if you
# need lower latency on the first request after idle (warm pool
# always present), and pair with PHP_FPM_START_SERVERS / _MIN_SPARE
# / _MAX_SPARE.
PHP_FPM_PM_MODE=ondemand
PHP_FPM_MAX_CHILDREN=4
PHP_FPM_IDLE_TIMEOUT=60s
PHP_FPM_MAX_REQUESTS=500

# Build-only switch — read by `docker compose build core-builder`,
# not by any running container. Set to `release-small` for the
# low-mem-VPS install path; cuts peak compile-time RAM from ~1.5-2 GB
# to ~0.6-0.9 GB at the cost of ~5-15 % runtime speed. The default
# `release` profile in core/Cargo.toml stays the production target
# for boxes that can spare the build RAM.
#
# Used like:
#   docker compose --profile build-only build core-builder \
#       --build-arg CARGO_PROFILE=${CT_CORE_BUILD_PROFILE}
CT_CORE_BUILD_PROFILE=release
