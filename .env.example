# Cool Tunnel Server v0.5.3 environment template.
#
# Copy to .env, edit, then run:
#   ./ct install
#
# Generate strong secrets locally:
#   openssl rand -base64 48

# --- Public identity -------------------------------------------------
DOMAIN=proxy.example.com
PANEL_DOMAIN=panel.proxy.example.com
ACME_EMAIL=admin@example.com
ACME_DIRECTORY=https://acme-v02.api.letsencrypt.org/directory

# --- Admin API / Better Auth ----------------------------------------
APP_ENV=production
CT_ADMIN_ENV=production
CT_ADMIN_PORT=9000
CT_ADMIN_DB_PATH=./data/admin/admin.sqlite
CT_ADMIN_BOOTSTRAP_TOKEN_TTL_MINUTES=15
CT_ADMIN_SECURE_COOKIES=true
BETTER_AUTH_URL=https://${PANEL_DOMAIN}
BETTER_AUTH_SECRET=

# Public signup remains disabled unless a maintainer intentionally
# changes this for a private deployment.
CT_PUBLIC_SIGNUP=false

# --- Reality / sing-box ---------------------------------------------
# Generate or rotate these with the release tooling before production.
# They must be 43-character base64url X25519 keys.
REALITY_PRIVATE_KEY=
REALITY_PUBLIC_KEY=
REALITY_DEST_HOST=www.microsoft.com
REALITY_SHORT_IDS=

ANTI_TRACKING_HIDE_IP=true
ANTI_TRACKING_HIDE_VIA=true
ANTI_TRACKING_PROBE_RESISTANCE=true
ANTI_TRACKING_DOH_RESOLVER=https://dns.alidns.com/dns-query

SINGBOX_DIRECT_DOMAIN_STRATEGY=ipv4_only
SINGBOX_DIRECT_CONNECT_TIMEOUT=2s
SINGBOX_DIRECT_FALLBACK_DELAY=100ms

# Maintainer/dev-only Rust build switch. Production install/update uses
# prebuilt release assets.
CT_CORE_BUILD_PROFILE=release
