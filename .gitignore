# Secrets
.env
.env.*.local

# Composer / Laravel
panel/vendor/
panel/node_modules/
# PHPUnit 11 test-result cache. Created on every `make test` /
# `phpunit` run, scoped to a single working tree. (v0.0.47.)
panel/.phpunit.cache/
panel/storage/app/*
!panel/storage/app/.gitkeep
panel/storage/framework/cache/data/*
!panel/storage/framework/cache/data/.gitkeep
# Laravel's compiled-facade cache writes facade-<sha>.php directly
# into storage/framework/cache/ (bare-level, not under data/). The
# data/* glob above doesn't catch those. (v0.0.47.)
panel/storage/framework/cache/*.php
panel/storage/framework/sessions/*
!panel/storage/framework/sessions/.gitkeep
panel/storage/framework/views/*
!panel/storage/framework/views/.gitkeep
panel/storage/logs/*
!panel/storage/logs/.gitkeep
panel/bootstrap/cache/*
!panel/bootstrap/cache/.gitkeep
panel/public/storage
panel/public/hot

# Generated Caddyfile (lives in a Docker volume in prod; locally we
# don't want to commit a rendered file with secrets in it).
caddy/Caddyfile.rendered

# Editor / OS detritus
.DS_Store
.idea/
.vscode/
*.swp

# Backup tarballs from scripts/backup.sh
backups/

# Rust build artifacts (the workspace lives in core/)
core/target/
**/target/

# sqlx offline metadata: core/.sqlx/ IS committed. Listed here as
# documentation — do NOT add `core/.sqlx` to ignore patterns. The
# directory holds the compile-time SQL type contract every build
# validates against (see docs/sqlx-offline.md, scripts/sqlx-prepare.sh).
# CI's sqlx-offline-check job fails if it's missing.

# Runtime + session artefacts (VPS-local, never committed)
.claude/
state/
results/
panel/.env.bak*
# Audit reports are VPS evidence, not git history (compliance via VPS file retention)
docs/audits/
